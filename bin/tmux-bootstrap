#!/usr/bin/env bash
# Create project tmux sessions, then attach via iTerm2 -CC integration.
# Existing sessions are left untouched.
#
# Usage:
#   tmux-bootstrap             # create autostart sessions + attach
#   tmux-bootstrap --start <n> # create and attach a single session
#   tmux-bootstrap --list      # show all sessions and their status
#   tmux-bootstrap --help      # show usage

set -euo pipefail

command -v tmux &>/dev/null || { echo "tmux not found" >&2; exit 1; }

# ── Sessions ────────────────────────────────────────────────────────
# name → starting directory
declare -A SESSIONS=(
  [mind]="$HOME/Documents/Mind"
  [dev]="$HOME/dev"
  [trek]="$HOME/dev"
  [matrix]="$HOME/dev"
  [yard]="$HOME/dev"
  [jam]="$HOME/dev"
  [studio]="$HOME/dev"
  [aicli]="$HOME/dev"
  [canoe]="$HOME/dev"
)

# Sessions to create and attach on bootstrap (subset of SESSIONS)
AUTOSTART=(mind dev)

# All sessions in preferred tab order (iTerm2 renders in creation order)
ORDER=(mind dev yard trek matrix jam studio aicli canoe)

# ── Windows ─────────────────────────────────────────────────────────
# session → space-separated window names (first window is created with session)
declare -A WINDOWS=(
  [mind]="FOCUS CAPTURE EXPLORE JUDGE DISTILL"
  [dev]="RESEARCH DESIGN CODE TEST OPS SCRATCH"
  [trek]="RIKER SPOCK GEORDI UHURA CHEKOV"
  [matrix]="NEO MORPHEUS TRINITY ORACLE TANK"
  [yard]="LORE PRAXIS COUNCIL FLEETS FORGE"
  [jam]="LEAD BASS DRUMS KEYS VAMP"
  [studio]="TRACK MIX BOOTH BOARD TAKE"
  [aicli]="OPENCODE CLAUDE GEMINI COPILOT"
  [canoe]="COLLECT ANALYZE NEED ORGANIZE EXECUTE"
)

# window-specific commands: session:window → command
declare -A COMMANDS=(
  [aicli:OPENCODE]="opencode"
  [aicli:CLAUDE]="claude"
  [aicli:GEMINI]="gemini"
  [aicli:COPILOT]="copilot"
)

# ── Validation ──────────────────────────────────────────────────────

validate_config() {
  local errors=0
  for name in "${ORDER[@]}"; do
    if [[ -z "${SESSIONS[$name]+x}" ]]; then
      echo "Config error: '$name' in ORDER but missing from SESSIONS" >&2
      errors=$((errors + 1))
    fi
  done
  if ((errors > 0)); then
    exit 1
  fi
}

validate_config

# ── Functions ───────────────────────────────────────────────────────

session_exists() { tmux has-session -t "$1" 2>/dev/null; }

is_autostart() {
  local target="$1" entry
  for entry in "${AUTOSTART[@]}"; do
    [[ "$entry" == "$target" ]] && return 0
  done
  return 1
}

# Create a session with its configured windows (no-op if exists).
# Returns 0 if created, 1 if already existed, 2 on error.
ensure_session() {
  local name="$1"
  local dir="${SESSIONS[$name]}"

  session_exists "$name" && return 1

  if [[ ! -d "$dir" ]]; then
    echo "  ✗ $name — directory not found: $dir" >&2
    return 2
  fi

  local windows="${WINDOWS[$name]:-}"
  if [[ -n "$windows" ]]; then
    read -ra win_list <<< "$windows"
    tmux new-session -d -s "$name" -n "${win_list[0]}" -c "$dir"

    # Run command in first window if configured
    local first_win="${win_list[0]}"
    if [[ -n "${COMMANDS["$name:$first_win"]:-}" ]]; then
      tmux send-keys -t "$name:$first_win" "${COMMANDS["$name:$first_win"]}" C-m
    fi

    # Create other windows and run their commands
    for win in "${win_list[@]:1}"; do
      tmux new-window -t "$name" -n "$win" -c "$dir"
      if [[ -n "${COMMANDS["$name:$win"]:-}" ]]; then
        tmux send-keys -t "$name:$win" "${COMMANDS["$name:$win"]}" C-m
      fi
    done
  else
    tmux new-session -d -s "$name" -c "$dir"
  fi
  return 0
}

# Attach to a single session.
# Uses -CC under iTerm2 (session windows become native tabs).
attach_session() {
  local name="$1"
  if [[ "${TERM_PROGRAM:-}" == "iTerm.app" ]]; then
    exec tmux -CC attach -t "$name"
  elif [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$name"
  else
    exec tmux attach -t "$name"
  fi
}

# ── Commands ────────────────────────────────────────────────────────

cmd_bootstrap() {
  echo "Creating sessions..."
  local created=0
  for name in "${AUTOSTART[@]}"; do
    if ensure_session "$name"; then
      local windows="${WINDOWS[$name]:-}"
      echo "  + $name → ${SESSIONS[$name]} (${windows})"
      created=$((created + 1))
    else
      echo "  ✓ $name (exists)"
    fi
  done
  echo ""
  echo "$created session(s) created."
  echo ""

  echo "Attaching to dev..."
  echo "  (open other sessions: Cmd+N then tmux-bootstrap --start <name>)"
  attach_session "dev"
}

cmd_start() {
  local name="$1"
  if [[ -z "${SESSIONS[$name]+x}" ]]; then
    echo "Unknown session: $name" >&2
    echo "Available: ${ORDER[*]}" >&2
    exit 1
  fi

  if ensure_session "$name"; then
    local windows="${WINDOWS[$name]:-}"
    echo "Created $name (${windows})"
  else
    echo "$name already running"
  fi

  attach_session "$name"
}

cmd_list() {
  echo "Autostart:"
  for name in "${AUTOSTART[@]}"; do
    if session_exists "$name"; then
      echo "  ✓ $name (running)"
    else
      echo "  · $name → ${SESSIONS[$name]}"
    fi
  done
  echo ""
  echo "Available (use --start <name>):"
  for name in "${ORDER[@]}"; do
    is_autostart "$name" && continue
    if session_exists "$name"; then
      echo "  ✓ $name (running)"
    else
      echo "  · $name → ${SESSIONS[$name]} (${WINDOWS[$name]:-})"
    fi
  done
}

usage() {
  echo "Usage: tmux-bootstrap [--list | --start <name> | --help]"
  echo ""
  echo "  (no args)       Create autostart sessions (mind, dev) and attach"
  echo "  --start <name>  Create and attach a single session"
  echo "  --list          Show all sessions and their status"
  echo "  --help          Show this message"
}

# ── Main ────────────────────────────────────────────────────────────

case "${1:-}" in
  --list)
    cmd_list
    ;;
  --start)
    [[ -z "${2:-}" ]] && { echo "Usage: tmux-bootstrap --start <name>" >&2; exit 1; }
    cmd_start "$2"
    ;;
  --help|-h)
    usage
    ;;
  "")
    cmd_bootstrap
    ;;
  *)
    echo "Unknown option: $1" >&2
    usage >&2
    exit 1
    ;;
esac
